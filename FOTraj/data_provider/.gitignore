# ========================
# Python & Environment
# ========================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.env
.ipynb_checkpoints/

# ========================
# FOTraj Specific Data
# ========================
# Ignore all raw and processed dataset files
datasets/**/*.txt
datasets/**/*.csv

# Ignore model checkpoints (these get massive quickly)
checkpoints/*
